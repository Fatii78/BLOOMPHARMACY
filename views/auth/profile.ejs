<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile</title>
  <style>
    body {
      font-family: "Patrick Hand", cursive, sans-serif;
      background-color: #ffffff;
      margin: 0;
      padding: 0;
      color: #0e2962;
    }

    h2 {
     margin: 20px 0 10px 0;
      font-weight: 600;
      font-size: 1.4rem;

    }

    .order-card {
      border: 1px solid #ccc;
      border-radius: 8px;
      padding: 15px 20px;
      margin: 15px 0;
      background-color: #fff;
      box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .order-card ul {
      list-style: disc;
      padding-left: 20px;
    }

    .order-card li {
      margin-bottom: 5px;
    }

    .order-card p {
      margin: 5px 0;
    }
    .container {
      max-width: 1000px;
      margin: 20px auto;
      padding: 0 15px;
    }
  </style>
</head>
<body>

  <%- include("../partials/header.ejs") %>

  <div class="container">
    <h2>My Orders</h2>
    <% if (orders.length === 0) { %>
      <p>No orders</p>
    <% } else { %>
      <% orders.forEach(order => { %>
        <div class="order-card">
          <div class="order-header">
            <p><strong>Status:</strong> <%= order.status %></p>
            <p><strong>Total:</strong> <%= order.total %> BD</p>
            <p><strong>Date:</strong> <%= order.createdAt.toDateString() %></p>
          </div>
          <h4>Items:</h4>
          <ul>
            <% order.items.forEach(item => { %>
              <li><%= item.name %> - <%= item.quantity %> x <%= item.price %></li>
            <% }) %>
          </ul>
        </div>
      <% }) %>
    <% } %>
  </div>

  <%- include("../partials/footer.ejs") %>
</body>
</html>
