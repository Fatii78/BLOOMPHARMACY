<head>
<style>
/* Center container */
.star-container {
  display: flex;
  justify-content: center;
  align-items: center; /* vertical center if needed */
  margin: 20px 0;
}

/* Star rating container */
.star-rating {
  direction: rtl; /* for right-to-left to make CSS easier */
  display: flex;
  font-size: 2.5rem;
}

/* Hide radio buttons */
.star-rating input {
  display: none;
}

/* Stars default (empty) */
.star-rating label {
  color: #ccc; /* empty star color */
  cursor: pointer;
  transition: color 0.2s;
}

/* Hover effect */
.star-rating label:hover,
.star-rating label:hover ~ label {
  color: gold;
}

/* Checked stars */
.star-rating input:checked ~ label,
.star-rating input:checked + label,
.star-rating label.selected {
  color: gold;
}
</style>
</head>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="style.css" />
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Products</title>
</head>

<body>
<%- include("../partials/header") %>


<div class="products-page-container">
<% if (products.length === 0) { %>
<p class="no-products">No products found.</p>
<% } else { %>
<div class="products-grid">
<% products.forEach(product => { %>
<div class="product-card">
<a href="/products/<%= product._id %>">
<div class="product-image-wrapper">
<img src="<%= product.imageUrl %>" alt="<%= product.name %>">

</div>
</a>

<div class="product-info">
<a href="/products/<%= product._id %>" class="product-name">
<%= product.name %>
</a>
<p class="product-price">
<%= product.price %> BHD
</p>

<form action="/cart/add" method="POST">
<input type="hidden" name="productId" value="<%= product._id %>">
<button class="add-cart-btn">
Add Cart
</button>
</form>
</div>

    <div class="review-form">
        <h3>Submit a Review</h3>
        <form id="reviewForm" action="/products/<%= product._id %>/review" method="POST">

        <div class="star-rating">
          <label for="star5">☆</label><label for="star5">☆</label><label for="star5">☆</label><label for="star5">☆</label><label for="star5">☆</label>
        </div>

        <label for="comment">Comment:</label>
        <textarea name="comment" id="comment" rows="4" required></textarea>
        <button type="submit">Submit Review</button>
        </form>
    </div>
<script>
  const stars = document.querySelectorAll('.star-rating input');

  stars.forEach(star => {
    star.addEventListener('click', function () {
      if (this.wasChecked) {
        this.checked = false;
        this.wasChecked = false;
      } else {
        stars.forEach(s => s.wasChecked = false);
        this.wasChecked = true;
      }
    });
  });
</script>
</div>
</div>
</div>
<% }) %>
</div>
<% } %>
</div>

<%- include("../partials/footer.ejs") %>
</body>
</html>
